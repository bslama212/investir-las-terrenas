---
import { getCollection } from 'astro:content';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { CONTACT } from '../../consts';

const properties = (await getCollection('properties', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const nf = new Intl.NumberFormat('fr-FR');
const cur = (n: number, c: string) => `${nf.format(n)} ${c === 'USD' ? '$' : '€'}`;
---
<MarketingLayout
  title="Biens à la vente à Las Terrenas — Sélection Hereles"
  description="La sélection de biens à la vente à Las Terrenas, analysés et sécurisés par Cabinet Hereles. Conseil objectif du côté de l'acquéreur, biens off-market sur demande."
  path="/biens"
>
  <section class="section section--ink biens-head">
    <div class="container">
      <span class="eyebrow" data-reveal>Sélection Hereles</span>
      <h1 data-reveal>Biens à la vente à Las Terrenas</h1>
      <p class="lead" data-reveal>Chaque bien présenté ici a été <strong>analysé et sécurisé</strong> selon notre méthode — titre, prix de marché, rendement réaliste. Nous sourçons aussi des biens <strong>off-market</strong> que nous présentons sur demande.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="biens-grid">
        {properties.map((p) => (
          <a href={`/biens/${p.slug}`} class="biens-card" data-reveal>
            {p.data.images.length > 0 && (
              <div class="biens-card__img"><img src={p.data.images[0].src} alt={p.data.images[0].alt} loading="lazy" /></div>
            )}
            <div class="biens-card__top">
              <span class="badge badge--solid">{p.data.confotur ? 'CONFOTUR' : 'Analysé'}</span>
              <span class="biens-card__ref">{p.data.ref}</span>
            </div>
            <h2>{p.data.title}</h2>
            <p class="biens-card__loc">{p.data.location}</p>
            <ul class="biens-card__chips">
              {p.data.pieces && <li>{p.data.pieces} pièces</li>}
              {p.data.surfaceM2 && <li>{p.data.surfaceM2} m²</li>}
              {p.data.floor && <li>{p.data.floor}</li>}
            </ul>
            <p class="biens-card__summary">{p.data.summary}</p>
            <div class="biens-card__foot">
              <span class="biens-card__price">{cur(p.data.price, p.data.currency)}</span>
              <span class="biens-card__cta">Voir le bien →</span>
            </div>
          </a>
        ))}

        <div class="biens-offmarket" data-reveal>
          <h2>Un projet précis ?</h2>
          <p>Dites-nous votre budget, votre objectif (revenu, usage, patrimoine) et votre horizon : nous activons notre réseau d'agences et nos pistes <strong>off-market</strong> pour vous présenter les biens qui servent vraiment votre projet.</p>
          <div class="btn-row">
            <a href={CONTACT.whatsapp} class="btn btn--wa btn--lg" target="_blank" rel="noopener">WhatsApp</a>
            <a href={CONTACT.calendly} class="btn btn--primary btn--lg" target="_blank" rel="noopener">Réserver un appel</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .biens-head { padding-top: clamp(3rem, 7vw, 5rem); padding-bottom: clamp(2rem, 5vw, 3rem); }
  .biens-head h1 { margin: 1rem 0 0.8rem; }
  .biens-head .lead { color: var(--muted-light); max-width: 46rem; }

  .biens-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 760px) { .biens-grid { grid-template-columns: repeat(2, 1fr); } }

  .biens-card { display: flex; flex-direction: column; background: var(--paper); border: 1px solid var(--line); border-radius: 16px; overflow: hidden; padding: 1.5rem; text-decoration: none; color: inherit; transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease; }
  .biens-card:hover { transform: translateY(-3px); box-shadow: 0 22px 44px -30px rgba(12,26,22,0.45); border-color: var(--brass); }
  .biens-card__img { margin: -1.5rem -1.5rem 1.2rem; }
  .biens-card__img img { width: 100%; height: 220px; object-fit: cover; display: block; }
  .biens-card__top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .biens-card__ref { font-family: var(--font-mono); font-size: 0.72rem; color: var(--muted); }
  .biens-card h2 { font-size: 1.35rem; margin: 0 0 0.3rem; }
  .biens-card__loc { font-size: 0.88rem; color: var(--muted); margin-bottom: 0.9rem; }
  .biens-card__chips { list-style: none; padding: 0; margin: 0 0 0.9rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .biens-card__chips li { font-family: var(--font-mono); font-size: 0.72rem; padding: 0.3em 0.7em; border: 1px solid var(--line); border-radius: 999px; color: var(--ink); }
  .biens-card__summary { font-size: 0.92rem; color: var(--ink); line-height: 1.55; margin-bottom: 1.2rem; flex-grow: 1; }
  .biens-card__foot { display: flex; justify-content: space-between; align-items: baseline; border-top: 1px solid var(--line); padding-top: 1rem; }
  .biens-card__price { font-family: var(--font-display); font-size: 1.4rem; font-weight: 600; color: var(--ink); }
  .biens-card__cta { font-family: var(--font-mono); font-size: 0.82rem; color: var(--emerald); }

  .biens-offmarket { background: var(--emerald); color: var(--bone); border-radius: 16px; padding: 1.8rem; display: flex; flex-direction: column; justify-content: center; }
  .biens-offmarket h2 { color: var(--bone); font-size: 1.35rem; margin: 0 0 0.6rem; }
  .biens-offmarket p { color: var(--muted-light); font-size: 0.92rem; line-height: 1.6; margin-bottom: 1.3rem; }
  .biens-offmarket .btn-row { display: flex; gap: 0.7rem; flex-wrap: wrap; }
</style>
