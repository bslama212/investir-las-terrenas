---
import { getCollection } from 'astro:content';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import Faq from '../../components/Faq.astro';
import CtaBand from '../../components/CtaBand.astro';
import { SITE, FOUNDER, SOCIAL, LEGAL } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const dateFmt = (date: Date) => date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
const url = `${SITE.url}/blog/${entry.slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.description,
  datePublished: d.pubDate.toISOString(),
  dateModified: (d.updatedDate ?? d.pubDate).toISOString(),
  articleSection: d.category,
  inLanguage: 'fr-FR',
  mainEntityOfPage: url,
  author: { '@type': 'Person', name: d.author, url: SOCIAL.linkedin },
  publisher: { '@type': 'Organization', name: LEGAL.parentBrand, url: LEGAL.parentUrl },
  image: new URL(SITE.ogImage, SITE.url).href,
};
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE.url}/blog` },
    { '@type': 'ListItem', position: 3, name: d.title, item: url },
  ],
};
---
<MarketingLayout title={d.title} description={d.description} path={`/blog/${entry.slug}`} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  </Fragment>

  <section class="section section--ink page-hero">
    <div class="container narrow">
      <nav class="crumbs" aria-label="Fil d'Ariane"><a href="/">Accueil</a> <span>/</span> <a href="/blog">Blog</a> <span>/</span> <span>{d.category}</span></nav>
      <span class="eyebrow">{d.category}</span>
      <h1>{d.title}</h1>
      <p class="article-meta">Par {d.author} · {dateFmt(d.pubDate)}{d.updatedDate && ` · mis à jour le ${dateFmt(d.updatedDate)}`}</p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <article class="prose"><Content /></article>
    </div>
  </section>

  {d.faq && d.faq.length > 0 && (
    <section class="section section--paper">
      <div class="container narrow"><Faq items={d.faq} title="Questions fréquentes" /></div>
    </section>
  )}

  <CtaBand />
</MarketingLayout>

<style>
  .page-hero h1 { margin: 1rem 0 0.8rem; }
  .crumbs { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted-light); margin-bottom: 1.4rem; }
  .crumbs a { color: var(--brass); } .crumbs span { opacity: 0.6; }
  .article-meta { font-family: var(--font-mono); font-size: 0.82rem; color: var(--muted-light); }
</style>
