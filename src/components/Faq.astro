---
interface FaqItem { q: string; a: string; }
interface Props { items: FaqItem[]; title?: string; emitSchema?: boolean; }
const { items, title, emitSchema = true } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a },
  })),
};
---
<div class="faq">
  {title && <h2 class="faq__title">{title}</h2>}
  <div class="faq__list">
    {items.map((it, i) => (
      <details class="faq__item" name="faq" open={i === 0}>
        <summary>
          <span>{it.q}</span>
          <span class="faq__icon" aria-hidden="true"></span>
        </summary>
        <div class="faq__answer"><p set:html={it.a} /></div>
      </details>
    ))}
  </div>
</div>

{emitSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

<style>
  .faq__title { margin-bottom: 2rem; }
  .faq__item { border-bottom: 1px solid var(--line); }
  .section--ink .faq__item, .section--emerald .faq__item { border-color: var(--line-dark); }
  .faq__item summary {
    display: flex; justify-content: space-between; align-items: center; gap: 1.5rem;
    padding: 1.25rem 0; cursor: pointer; list-style: none; font-family: var(--font-display);
    font-size: clamp(1.05rem, 2vw, 1.25rem); font-weight: 460;
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__icon { position: relative; width: 16px; height: 16px; flex-shrink: 0; }
  .faq__icon::before, .faq__icon::after { content: ""; position: absolute; background: var(--brass-deep); transition: transform 0.25s ease; }
  .faq__icon::before { top: 7px; left: 0; width: 16px; height: 2px; }
  .faq__icon::after { top: 0; left: 7px; width: 2px; height: 16px; }
  .faq__item[open] .faq__icon::after { transform: scaleY(0); }
  .faq__answer { overflow: hidden; padding-bottom: 1.3rem; max-width: 60ch; }
  .faq__answer p { color: var(--muted); }
  .section--ink .faq__answer p, .section--emerald .faq__answer p { color: var(--muted-light); }
  .faq__answer a { color: var(--brass-deep); text-decoration: underline; text-underline-offset: 2px; }
</style>
