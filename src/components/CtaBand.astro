---
import { CONTACT } from '../consts';
interface Props {
  title?: string;
  text?: string;
  variant?: 'emerald' | 'ink';
}
const {
  title = 'Parlons de votre projet à Las Terrenas',
  text = "Un premier échange, sans engagement, pour cadrer votre budget, vos objectifs de rendement et la faisabilité. Vous repartez avec une vision claire — pas un argumentaire de vente.",
  variant = 'emerald',
} = Astro.props;
---
<section class={`section cta-band section--${variant}`}>
  <div class="container cta-band__inner">
    <div class="cta-band__text">
      <span class="eyebrow">Prochaine étape</span>
      <h2>{title}</h2>
      <p class="lead">{text}</p>
    </div>
    <div class="cta-band__actions">
      <a href={CONTACT.calendly} class="btn btn--primary btn--lg" target="_blank" rel="noopener">Réserver un appel stratégique</a>
      <a href={CONTACT.whatsapp} class="btn btn--ghost btn--lg" target="_blank" rel="noopener">Discuter sur WhatsApp</a>
      <a href={CONTACT.phoneHref} class="cta-band__phone">ou {CONTACT.phoneDisplay}</a>
    </div>
  </div>
</section>

<style>
  .cta-band__inner { display: grid; grid-template-columns: 1.3fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .cta-band__text h2 { margin: 0.8rem 0 1rem; }
  .cta-band__actions { display: flex; flex-direction: column; gap: 0.8rem; align-items: flex-start; }
  .cta-band__actions .btn { width: 100%; }
  .cta-band__phone { font-family: var(--font-mono); font-size: 0.85rem; opacity: 0.85; margin-top: 0.2rem; }
  @media (max-width: 860px) { .cta-band__inner { grid-template-columns: 1fr; } }
</style>
